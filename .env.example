# AIDSTATION env vars — copy to .env and fill in.
#
# Booleans accept 0/1, true/false, yes/no, on/off (anything else is true).
# .env is gitignored; never commit secrets.

# ─── Required ────────────────────────────────────────────────────────────────

# Flask session signing. App refuses to boot without this.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# ─── Required in production (omit for local SQLite dev) ──────────────────────

# Postgres connection string. When unset, the app uses a local SQLite DB at
# instance/training.db. Production is on Neon Postgres.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Anthropic API key. Coaching / AI features are disabled if unset.
# ANTHROPIC_API_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────

# Comma-separated old SECRET_KEYs accepted during a rotation drain. New
# cookies are signed with SECRET_KEY; old cookies still verify until they
# expire or this is removed.
# SECRET_KEY_FALLBACK=

# Override the auto-on-when-DATABASE_URL-is-set behavior. Set to 0 if running
# behind a non-HTTPS proxy in dev with DATABASE_URL pointed at a remote DB.
# SESSION_COOKIE_SECURE=1

# Swap Flask-Limiter's storage to Redis if scaling beyond a single instance.
# RATELIMIT_STORAGE_URI=redis://...

# Ship CSP as report-only while debugging policy violations.
# CSP_REPORT_ONLY=1

# Close registration. Useful for production once initial users are seeded.
# ALLOW_REGISTRATION=0

# SendGrid email. Without these set, password-reset links are logged to stdout.
# SENDGRID_API_KEY=
# EMAIL_FROM_ADDRESS=
# EMAIL_FROM_NAME=

# Override Claude model used for coaching. Defaults match coaching.py.
# CLAUDE_MODEL=

# Default location string used by the conditions log when none is selected.
# WEATHER_LOCATION=
