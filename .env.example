# AIDSTATION env vars — copy to .env and fill in.
#
# Booleans accept 0/1, true/false, yes/no, on/off (anything else is true).
# .env is gitignored; never commit secrets.

# ─── Required ────────────────────────────────────────────────────────────────

# Flask session signing. App refuses to boot without this.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# ─── Required in production (omit for local SQLite dev) ──────────────────────

# Postgres connection string. When unset, the app uses a local SQLite DB at
# instance/training.db. Production is on Neon Postgres.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Anthropic API key. Coaching / AI features are disabled if unset.
# ANTHROPIC_API_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────

# Comma-separated old SECRET_KEYs accepted during a rotation drain. New
# cookies are signed with SECRET_KEY; old cookies still verify until they
# expire or this is removed.
# SECRET_KEY_FALLBACK=

# Override the auto-on-when-DATABASE_URL-is-set behavior. Set to 0 if running
# behind a non-HTTPS proxy in dev with DATABASE_URL pointed at a remote DB.
# SESSION_COOKIE_SECURE=1

# Swap Flask-Limiter's storage to Redis if scaling beyond a single instance.
# RATELIMIT_STORAGE_URI=redis://...

# Ship CSP as report-only while debugging policy violations.
# CSP_REPORT_ONLY=1

# Close registration. Useful for production once initial users are seeded.
# ALLOW_REGISTRATION=0

# Vercel Blob read/write token — backs crowd-sourced gym/hotel profile photo
# uploads (#971 Slice 2). Without it, the photo-upload form reports "not
# configured" and equipment editing is otherwise unaffected. Provisioned in the
# Vercel project's Storage tab; also needed as a CI secret only if photo-route
# integration tests run live (the unit tests stub the Blob call).
# BLOB_READ_WRITE_TOKEN=

# SendGrid email. Without these set, password-reset links are logged to stdout.
# SENDGRID_API_KEY=
# EMAIL_FROM_ADDRESS=
# EMAIL_FROM_NAME=

# Shared transactional-email shell values (every template under email/ uses
# these — see email/HANDOFF.md).
# PUBLIC_BASE_URL       — absolute origin for links + the header logo in mail
#                         rendered with no request context (e.g. the plan emails
#                         fired from cron). Defaults to https://app.aidstation.pro.
# EMAIL_SUPPORT_ADDRESS — support address shown in every footer + receipt copy.
#                         Defaults to support@aidstation.pro.
# EMAIL_COMPANY_ADDRESS — postal-address line in the footer; the separator is
#                         omitted entirely when this is unset.
# PUBLIC_BASE_URL=
# EMAIL_SUPPORT_ADDRESS=
# EMAIL_COMPANY_ADDRESS=

# Override Claude model used for coaching. Defaults match coaching.py.
# CLAUDE_MODEL=

# Default location string used by the conditions log when none is selected.
# WEATHER_LOCATION=

# ─── Provider OAuth integrations (optional) ──────────────────────────────────
#
# Each provider's "Connect" button is dark/erroring until BOTH its CLIENT_ID
# and CLIENT_SECRET are set here AND the developer-portal redirect_uri is
# registered EXACTLY as shown below (scheme + host + path, no trailing slash).
# A mismatched/absent redirect_uri is the usual cause of "the provider login
# page showed but errored right after I logged in" — the provider rejects the
# authorization the moment it validates the callback URL.
#
# redirect_uri to register = https://<your-host>/<slug>/oauth/callback
#   (prod host: https://aidstation-pro.vercel.app)
#
# WAHOO_CLIENT_ID=
# WAHOO_CLIENT_SECRET=
# WAHOO_WEBHOOK_TOKEN=          # echoed back in each workout_summary push; gates the webhook
#   redirect_uri: https://aidstation-pro.vercel.app/wahoo/oauth/callback
#
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_SUBSCRIPTION_ID=       # from the push-subscription create call
#   redirect_uri: https://aidstation-pro.vercel.app/strava/oauth/callback
#
# WHOOP_CLIENT_ID=
# WHOOP_CLIENT_SECRET=
#   redirect_uri: https://aidstation-pro.vercel.app/whoop/oauth/callback
#
# OURA_CLIENT_ID=
# OURA_CLIENT_SECRET=
#   redirect_uri: https://aidstation-pro.vercel.app/oura/oauth/callback
#
# COROS_CLIENT_ID= / COROS_CLIENT_SECRET=   → /coros/oauth/callback
# POLAR_CLIENT_ID= / POLAR_CLIENT_SECRET= / POLAR_WEBHOOK_SECRET= → /polar/oauth/callback
# RWGPS_CLIENT_ID= / RWGPS_CLIENT_SECRET=   → /ride-with-gps/oauth/callback

# ─── Diagnostics (read past the app login wall) ──────────────────────────────

# Shared service token for the agent-readable diagnostic endpoints:
# /admin/plan/<id>/diag and /admin/logs. Supplied as `X-Diag-Token` header or
# `?token=`. When unset there is NO token bypass — only an admin session reads.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# DIAG_TOKEN=

# Vercel Log Drain sink (issue #350). LOG_DRAIN_SECRET is the drain's signing
# secret — the ingest endpoint verifies the x-vercel-signature HMAC-SHA1
# against it and rejects unsigned/mismatched POSTs (no open-ingest bypass when
# unset). LOG_DRAIN_VERIFY is the x-vercel-verify ownership token Vercel hands
# you when creating the drain; the endpoint echoes it back as a response
# header. Set both, then point a Vercel Log Drain at /admin/logs/drain.
# LOG_DRAIN_SECRET=
# LOG_DRAIN_VERIFY=
